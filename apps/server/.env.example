# Claude API — server-side ONLY. Never exposed to the client or to sandboxed
# generated code.
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6

# Supabase (Postgres). Leave blank to run with the in-memory dev store —
# everything works, but nothing persists across restarts.
# Apply src/db/schema.sql to the project before first use.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

PORT=3001

# Force the worker_threads sandbox even if isolated-vm built: SANDBOX=worker
SANDBOX=auto
